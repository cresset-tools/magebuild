{
    "name": "cresset/magebuild",
    "description": "A fast, parallel, DAG-ordered Magento 2 build orchestrator: composer install, di-compile, static-content deploy, autoload dump, and packaging in one process, for CI / Deployer build steps. Fetches a prebuilt Rust binary on demand.",
    "type": "library",
    "license": "EUPL-1.2",
    "keywords": ["magento", "magento2", "cli", "deployer", "build", "ci", "developer-tools"],
    "homepage": "https://github.com/cresset-tools/magebuild",
    "authors": [
        { "name": "Jelle Besseling", "email": "jelle@pingiun.com" }
    ],
    "require": {
        "php": ">=8.1"
    },
    "suggest": {
        "ext-curl": "Faster, more reliable binary downloads",
        "ext-zip": "Required to install on Windows (the binary ships as a .zip)"
    },
    "bin": ["bin/magebuild"],
    "extra": {
        "bougie": {
            "default-bin": "bin/magebuild",
            "native-binary": {
                "spec": 1,
                "name": "magebuild",
                "tag-prefix": "magebuild-v",
                "base-urls": [
                    "https://releases.bougie.tools/github/magebuild/releases/download",
                    "https://github.com/cresset-tools/magebuild/releases/download"
                ],
                "targets": [
                    "x86_64-unknown-linux-gnu",
                    "x86_64-unknown-linux-musl",
                    "aarch64-unknown-linux-gnu",
                    "aarch64-apple-darwin",
                    "x86_64-apple-darwin",
                    "x86_64-pc-windows-msvc"
                ],
                "sigstore": {
                    "repository": "cresset-tools/magebuild"
                }
            }
        }
    }
}
